{"dialogue_id": "dlg_00020", "domain": "finance", "turns": [{"role": "user", "text": "I'd like to open a new savings account."}, {"role": "user", "text": "What are the current interest rates?"}, {"role": "user", "text": "Is there a minimum balance requirement?"}, {"role": "user", "text": "How many free withdrawals do I get per month?"}, {"role": "user", "text": "Are there any monthly maintenance fees?"}, {"role": "user", "text": "Can I link it to my existing checking account?"}, {"role": "user", "text": "Do you offer online and mobile banking?"}, {"role": "user", "text": "How quickly can I transfer funds between accounts?"}, {"role": "user", "text": "Is my money FDIC insured?"}, {"role": "user", "text": "What documents do I need to open the account?"}, {"role": "user", "text": "Can I open it entirely online?"}, {"role": "user", "text": "How do I make my initial deposit?"}, {"role": "user", "text": "Will I receive a debit card for this account?"}, {"role": "user", "text": "Are there any ATM fees?"}, {"role": "user", "text": "What's the daily withdrawal limit?"}, {"role": "user", "text": "Can I set up automatic transfers from my paycheck?"}, {"role": "user", "text": "Do you offer overdraft protection?"}, {"role": "user", "text": "How are interest payments calculated and credited?"}, {"role": "user", "text": "Is the interest rate variable or fixed?"}, {"role": "user", "text": "Can I have multiple savings accounts?"}, {"role": "user", "text": "What happens if my balance falls below the minimum?"}, {"role": "user", "text": "Are there fees for closing the account?"}, {"role": "user", "text": "Do you offer paper statements or only electronic?"}, {"role": "user", "text": "How can I update my personal information?"}, {"role": "user", "text": "Is there a fee for wire transfers?"}, {"role": "user", "text": "Can I make mobile check deposits?"}, {"role": "user", "text": "What's the process for reporting a lost card?"}, {"role": "user", "text": "Do you offer any sign-up bonuses?"